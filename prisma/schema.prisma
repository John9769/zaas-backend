// ============================================
// ZAAS DATABASE SCHEMA
// Phase 1 — PAYG Image to Cinematic Video
// Stack: Groq Vision + Wavespeed + VACE Joiner
// Casual: RM29.99 | Product: RM49.99
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS
// Guest checkout supported (no password)
// Registered users get order history
// ============================================
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  phone         String?
  password      String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  orders        Order[]
}

// ============================================
// TEMPLATES
// Niche templates — defines style per event type
// No AI prompt here — Groq generates dynamically
// ============================================
model Template {
  id              String   @id @default(uuid())
  name            String   // "Wedding Memories"
  slug            String   @unique // "wedding-memories"
  category        String   // casual | product
  niche           String   // wedding | birthday | travel | festive | graduation | me | product
  tagline         String   // "Turn your wedding photos into cinematic magic"
  description     String
  best_for        String   // "Weddings, solemnizations, receptions"

  // UI Assets
  preview_url     String?  // pre-rendered demo video on Cloudinary
  thumbnail_url   String?  // template card cover image

  // Pricing
  price           Decimal  @db.Decimal(10, 2) // 29.99 casual | 49.99 product

  sort_order      Int
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  orders          Order[]
}

// ============================================
// ORDERS
// One order = one 20-sec cinematic video
// 4 photos → 4 Wavespeed clips → VACE stitch
// Lifecycle: created → paid → processing → stitching → completed | failed
// ============================================
model Order {
  id            String   @id @default(uuid())

  // User
  user_id       String?
  user          User?    @relation(fields: [user_id], references: [id])
  guest_email   String?

  // Template
  template_id   String
  template      Template @relation(fields: [template_id], references: [id])
  category      String   // casual | product
  niche         String   // wedding | birthday | travel | festive | graduation | me | product
  amount        Decimal  @db.Decimal(10, 2) // 29.99 | 49.99

  // ==================
  // GROQ VISION ANALYSIS
  // Groq reads all 4 photos → detects event → generates prompts
  // ==================
  groq_event_type   String?  // wedding | birthday | travel | festive | graduation | me | product
  groq_analysis     String?  // full JSON from Groq — mood, people, setting, confidence
  groq_prompts      String?  // JSON array of 4 Wavespeed-optimized prompts

  // ==================
  // PAYMENT (Billplz FPX)
  // Pay FIRST → render AFTER
  // ==================
  payment_status    String    @default("pending")
  // pending | paid | failed
  billplz_bill_id   String?   @unique
  billplz_bill_url  String?
  paid_at           DateTime?

  // ==================
  // VIDEO GENERATION (Wavespeed async)
  // 4 parallel I2V calls → VACE stitch
  // ==================
  video_status        String    @default("pending")
  // pending | processing | stitching | completed | failed
  wavespeed_job_ids   String?   // JSON array of 4 Wavespeed job IDs
  wavespeed_clip_urls String?   // JSON array of 4 generated clip URLs
  vace_job_id         String?   // VACE Video Joiner job ID
  failure_reason      String?

  // ==================
  // FINAL OUTPUT
  // ==================
  video_url           String?   // Cloudinary final video URL
  video_public_id     String?   // Cloudinary public ID
  video_thumbnail     String?   // first frame thumbnail
  video_duration      Float?    // total seconds
  download_count      Int       @default(0)

  // ==================
  // REFUND
  // Auto-triggered if video_status = failed
  // ==================
  refund_status       String?   // null | pending | refunded
  refunded_at         DateTime?

  // ==================
  // EXPIRY — 30 days after completion
  // ==================
  expires_at          DateTime?
  expiry_notified     Boolean   @default(false)
  is_expired          Boolean   @default(false)

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  photos              OrderPhoto[]
}

// ============================================
// ORDER PHOTOS
// Exactly 4 photos per order
// Each photo gets its own Groq prompt + Wavespeed clip
// ============================================
model OrderPhoto {
  id                    String   @id @default(uuid())
  order_id              String
  order                 Order    @relation(fields: [order_id], references: [id])

  cloudinary_url        String   // uploaded photo URL
  cloudinary_public_id  String   // for cleanup

  sort_order            Int      // 1-4, sequence in final video
  file_size_kb          Int?
  width                 Int?
  height                Int?

  // Groq generated prompt for this specific photo
  groq_clip_prompt      String?  // Wavespeed-optimized motion prompt

  // Wavespeed output for this photo
  wavespeed_job_id      String?  // individual job ID
  wavespeed_clip_url    String?  // generated 5-sec clip URL

  created_at            DateTime @default(now())
}